# ─────────────────────────────────────────────────────────────
# 🔗 Network Layer (WebSocket + FastAPI)
# ─────────────────────────────────────────────────────────────

class ĐukaNode:
    """Core Đuka Protocol Node"""
    
    def __init__(
        self,
        node_id: Optional[str] = None,
        node_type: NodeType = NodeType.WORKER,
        host: str = "127.0.0.1",
        port: int = 8080,
        connect_to: Optional[str] = None
    ):
        self.node_id = node_id or str(uuid.uuid4())[:8]
        self.node_type = node_type
        self.host = host
        self.port = port
        self.connect_to = connect_to
        
        self.knowledge = KnowledgeStore(self.node_id)
        self.federated_index = FederatedIndex()
        
        self.app: Optional[FastAPI] = None
        self.websocket: Optional[WebSocket] = None
        self.peers: Dict[str, WebSocket] = {}
        
        self._handlers: Dict[str, Callable] = {}
        self._running = False
        
        logger.info(f"🧠 Đuka Node initialized: {self.node_id} [{node_type.value}]")
    
    def register_handler(self, msg_type: str, handler: Callable):
        """Register async handler for message type"""
        self._handlers[msg_type] = handler
        logger.debug(f"🔗 Registered handler for: {msg_type}")
    
    async def publish(self, message: Message):
        """Publish message to connected peers"""
        if not self.peers and not self.connect_to:
            logger.warning("⚠️ No peers to publish to")
            return
            
        payload = message.to_json()
        for peer_id, ws in self.peers.items():
            try:
                await ws.send_text(payload)
                logger.debug(f"📤 Sent to {peer_id}")
            except Exception as e:
                logger.error(f"❌ Failed to send to {peer_id}: {e}")
                await self._disconnect_peer(peer_id)
    
    async def _handle_message(self, raw: str, ws: Optional[WebSocket] = None):
        """Process incoming message"""
        try:
            msg = Message.from_json(raw)
            logger.debug(f"📥 Received [{msg.type}] from {msg.sender}")
            
            # Auto-handle protocol messages
            if msg.type == MessageType.HEARTBEAT.value:
                await self._handle_heartbeat(msg, ws)
                return
                
            # Route to registered handler
            handler = self._handlers.get(msg.type)
            if handler:
                if asyncio.iscoroutinefunction(handler):
                    await handler(msg)
                else:
                    handler(msg)
            else:
                logger.warning(f"⚠️ No handler for message type: {msg.type}")
                
        except json.JSONDecodeError as e:
            logger.error(f"❌ Invalid JSON: {e}")
        except Exception as e:
            logger.error(f"❌ Error handling message: {e}", exc_info=True)
    
    async def _handle_heartbeat(self, msg: Message, ws: WebSocket):
        """Respond to heartbeat"""
        response = Message(
            type=MessageType.HEARTBEAT.value,
            sender=self.node_id,
            payload={"status": "alive", "timestamp": datetime.now().timestamp()}
        )
        await ws.send_text(response.to_json())
    
    async def _disconnect_peer(self, peer_id: str):
        """Clean up disconnected peer"""
        if peer_id in self.peers:
            del self.peers[peer_id]
            logger.info(f"🔌 Disconnected: {peer_id}")
    
    # ─────────────────────────────────────────────────────────
    # 🚀 Server Mode (Hub)
    # ─────────────────────────────────────────────────────────
    
    def _setup_server(self):
        """Setup FastAPI server for hub mode"""
        if not HAS_FASTAPI:
            logger.error("❌ FastAPI not installed. Run: pip install fastapi uvicorn")
            return
            
        self.app = FastAPI(title=f"Đuka Node: {self.node_id}")
        
        @self.app.websocket("/ws")
        async def websocket_endpoint(websocket: WebSocket):
            await websocket.accept()
            peer_id = websocket.headers.get("X-Node-ID", str(uuid.uuid4())[:8])
            self.peers[peer_id] = websocket
            logger.info(f"🔗 Connected peer: {peer_id}")
            
            try:
                while True:
                    data = await websocket.receive_text()
                    await self._handle_message(data, websocket)
            except WebSocketDisconnect:
                await self._disconnect_peer(peer_id)
        
        logger.info(f"🌐 Server listening on ws://{self.host}:{self.port}/ws")
    
    async def run_server(self):
        """Run node as hub/server"""
        self._setup_server()
        if self.app:
            config = uvicorn.Config(
                self.app, host=self.host, port=self.port, log_level="info"
            )
            server = uvicorn.Server(config)
            await server.serve()
    
    # ─────────────────────────────────────────────────────────
    # 🔗 Client Mode (Worker)
    # ─────────────────────────────────────────────────────────
    
    async def connect_to_hub(self, hub_url: str):
        """Connect node to a hub"""
        if not HAS_FASTAPI:
            logger.error("❌ websockets not installed. Run: pip install websockets")
            return
            
        import websockets
        
        try:
            async with websockets.connect(
                hub_url, 
                extra_headers={"X-Node-ID": self.node_id}
            ) as websocket:
                logger.info(f"✅ Connected to hub: {hub_url}")
                
                # Send initial heartbeat
                heartbeat = Message(
                    type=MessageType.HEARTBEAT.value,
                    sender=self.node_id,
                    payload={"node_type": self.node_type.value}
                )
                await websocket.send(heartbeat.to_json())
                
                # Listen loop
                async for message in websocket:
                    await self._handle_message(message)
                    
        except ConnectionRefusedError:
            logger.error(f"❌ Could not connect to {hub_url}")
        except Exception as e:
            logger.error(f"❌ Connection error: {e}", exc_info=True)
    
    # ─────────────────────────────────────────────────────────
    # ▶️ Main Entry Point
    # ─────────────────────────────────────────────────────────
    
    async def start(self):
        """Start the node"""
        self._running = True
        
        if self.node_type == NodeType.HUB or not self.connect_to:
            # Run as server/hub
            await self.run_server()
        else:
            # Run as client/worker
            await self.connect_to_hub(self.connect_to)
    
    def stop(self):
        """Stop the node"""
        self._running = False
        logger.info(f"🛑 Node {self.node_id} stopping...")


# ─────────────────────────────────────────────────────────────
# 🎯 CLI Entry Point
# ─────────────────────────────────────────────────────────────

def main():
    import argparse
    
    parser = argparse.ArgumentParser(description="🧠 Đuka Protocol Node")
    parser.add_argument("--id", type=str, help="Node ID")
    parser.add_argument("--mode", type=str, default="worker", 
                       choices=["hub", "worker", "robot", "ai", "sim"])
    parser.add_argument("--host", type=str, default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8080)
    parser.add_argument("--connect", type=str, help="Hub URL to connect to")
    
    args = parser.parse_args()
    
    node = ĐukaNode(
        node_id=args.id,
        node_type=NodeType(args.mode),
        host=args.host,
        port=args.port,
        connect_to=args.connect
    )
    
    # Register default handlers
    @node.register_handler(MessageType.QUERY.value)
    async def handle_query(msg: Message):
        question = msg.payload.get("question", "")
        results = node.knowledge.search(question)
        response = Message(
            type=MessageType.RESPONSE.value,
            sender=node.node_id,
            payload={"results": [r.to_dict() for r in results]}
        )
        await node.publish(response)
    
    @node.register_handler(MessageType.INSIGHT_SHARE.value)
    async def handle_insight(msg: Message):
        insight_data = msg.payload.get("insight", {})
        insight = Insight(**insight_data)
        node.knowledge.store(insight)
        logger.info(f"💡 New insight from {msg.sender}: {insight.summary[:40]}...")
    
    try:
        asyncio.run(node.start())
    except KeyboardInterrupt:
        node.stop()


if __name__ == "__main__":
    main()
