class NodeType(Enum):
    HUB = "hub"           # Central coordinator
    WORKER = "worker"     # General purpose node
    ROBOT = "robot"       # Physical/simulated robot
    AI = "ai"            # AI/ML processing node
    SIM = "sim"          # Simulation environment


class MessageType(Enum):
    HEARTBEAT = "heartbeat"
    INSIGHT_SHARE = "insight_share"
    QUERY = "query"
    RESPONSE = "response"
    COMMAND = "command"
    ERROR = "error"


@dataclass
class Insight:
    """A unit of shared knowledge"""
    id: str = field(default_factory=lambda: str(uuid.uuid4()))
    summary: str = ""
    details: Dict = field(default_factory=dict)
    confidence: float = 1.0
    tags: List[str] = field(default_factory=list)
    source_node: str = ""
    timestamp: float = field(default_factory=datetime.now().timestamp)
    
    def to_dict(self) -> Dict:
        return asdict(self)


@dataclass
class Message:
    """Protocol message envelope"""
    msg_id: str = field(default_factory=lambda: str(uuid.uuid4()))
    type: str = ""
    sender: str = ""
    timestamp: float = field(default_factory=datetime.now().timestamp)
    payload: Dict = field(default_factory=dict)
    signature: Optional[str] = None  # For auth (future)
    
    def to_json(self) -> str:
        return json.dumps(asdict(self))
    
    @classmethod
    def from_json(cls, json_str: str) -> 'Message':
        data = json.loads(json_str)
        return cls(**data)


