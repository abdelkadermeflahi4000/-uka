        logger.info(f"📦 Stored insight: {insight.summary[:50]}...")
        
    def search(self, query: str, max_results: int = 5) -> List[Insight]:
        """Simple keyword search (placeholder for semantic search)"""
        results = [
            ins for ins in self.local_memory 
            if query.lower() in ins.summary.lower()
        ]
        return sorted(results, key=lambda x: x.confidence, reverse=True)[:max_results]
    
    def contribute(self, insight: Insight, global_index: Optional['FederatedIndex'] = None):
        """Share insight with network (if global index available)"""
        self.store(insight)
        if global_index:
