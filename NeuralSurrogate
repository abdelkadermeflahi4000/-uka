"""🤖 Neural Surrogate - نموذج بديل خفيف الوزن للفيزياء/الاقتصاد"""
import torch
import torch.nn as nn

class CausalSurrogateNet(nn.Module):
    def __init__(self, state_dim: int, action_dim: int, latent_dim: int = 64):
        super().__init__()
        # تشفير الحالة + التدخل
        self.encoder = nn.Sequential(
            nn.Linear(state_dim + action_dim, latent_dim),
            nn.ReLU(),
            nn.Linear(latent_dim, latent_dim)
        )
        # رأس سببي: يفصل التأثير المباشر عن الضوضاء
        self.causal_head = nn.Linear(latent_dim, state_dim)
        self.noise_head = nn.Linear(latent_dim, state_dim)
        
    def forward(self, state: torch.Tensor, action: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
        h = self.encoder(torch.cat([state, action], dim=-1))
        deterministic_outcome = self.causal_head(h)  # التأثير السببي المتوقع
        noise = self.noise_head(h)                   # عدم اليقين/الضوضاء الهيكلية
        return deterministic_outcome, noise

