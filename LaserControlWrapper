        # === الربط الجديد مع Noosphere ===
        if "noosphere" in self.env.unwrapped.__dict__:
            # إرسال تأثير الليزر إلى Noosphere
            beam_info = {
                "start": (x, y),
                "dir": dir_vec,
                "frequency": float(freq),
                "amplitude": float(amp)
            }
            self.env.unwrapped.noosphere.process_laser_impact([beam_info])
            
            # الحصول على تعديل من Noosphere
            mod = self.env.unwrapped.noosphere.get_laser_modulation(int(x), int(y))
            
            # تحسين المكافأة والدقة
            reward += mod["precision_bonus"] * 2.5
            reward += mod["stealth_bonus"] * 1.8
            
            # إضافة معلومات للـ info (للـ visualization والـ logging)
            info["noosphere_coherence"] = mod["coherence"]
            info["laser_precision_bonus"] = mod["precision_bonus"]
