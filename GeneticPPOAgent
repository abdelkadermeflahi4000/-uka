def get_perception_mask(self) -> np.ndarray:
    """الجين 8-10 يتحكم في كشف الأشعة الصامتة"""
    sensitivity = (self.genome.vector[8] + 1.0) / 2.0  # normalize to [0,1]
    threshold = 0.7
    # إذا كانت الحساسية < 0.7، يخفي الأشعة ذات التردد > 0.85 (صامتة)
    mask = np.ones((self.env.envs[0].grid_size, self.env.envs[0].grid_size))
    if sensitivity < threshold:
        mask[self.env.envs[0].freq_field > 0.85] = 0.0
    return mask
